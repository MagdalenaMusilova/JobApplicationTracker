<Window x:Class="JobApplicationTracker.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Job Application Tracker"
        Width="1400" Height="850"
        Background="#F3F4F6">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Background="#111827">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom" Margin="20 0 20 20">
                    <Button Content="Log out" Click="Logout_Click"
                            Background="#374151" Foreground="White"
                            Height="38" BorderThickness="0"/>
                </StackPanel>

                <StackPanel Margin="20">
                    <TextBlock Text="JobTracker"
                               FontSize="22" FontWeight="Bold"
                               Foreground="White" Margin="10 20 10 30"/>

                    <Button Content="Dashboard"   Click="Dashboard_Click"   Tag="Dashboard"/>
                    <Button Content="Applications" Click="Applications_Click" Tag="Applications"/>
                    <Button Content="Todo / Calendar" Click="Todo_Click"    Tag="Todo"/>
                    <Button Content="Profile"      Click="Profile_Click"    Tag="Profile"/>
                    <Button Content="Match Job"    Click="Match_Click"      Tag="Match"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>