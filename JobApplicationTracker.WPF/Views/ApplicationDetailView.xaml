<Page x:Class="JobApplicationTracker.Wpf.Views.ApplicationDetailView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F3F4F6">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="EditInput" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Overlay backdrop -->
        <Style x:Key="Overlay" TargetType="Border">
            <Setter Property="Background" Value="#88000000"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>

        <!-- Dialog panel -->
        <Style x:Key="Dialog" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="MinWidth" Value="380"/>
            <Setter Property="MaxWidth" Value="520"/>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Main scrollable content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30" MaxWidth="760" HorizontalAlignment="Left">

                <!-- Header row -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="32" FontWeight="Bold" Foreground="#111827">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding Company}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Text" Value="{Binding EditCompany}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock FontSize="15" Foreground="Gray">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding Position}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Text" Value="{Binding EditPosition}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <!-- View mode: Edit button -->
                        <Button Content="Edit"
                                Height="34" Padding="16,0" Margin="0,0,8,0"
                                Command="{Binding StartEditCommand}"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <!-- Edit mode: Save + Cancel -->
                        <Button Content="Save"
                                Height="34" Padding="16,0" Margin="0,0,8,0"
                                Command="{Binding ConfirmSaveCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Cancel"
                                Height="34" Padding="16,0" Margin="0,0,8,0"
                                Command="{Binding CancelEditCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="← Back" Height="34" Padding="16,0"
                                Click="Back_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Loading / Error -->
                <TextBlock Text="Loading…"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                           Foreground="Gray" Margin="0,0,0,12"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                           Foreground="#DC2626" TextWrapping="Wrap" Margin="0,0,0,12"/>

                <!-- Application Details  -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Application Details"/>

                        <!-- VIEW MODE -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Company"/>
                                    <TextBlock Style="{StaticResource FieldValue}" Text="{Binding Company}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Position"/>
                                    <TextBlock Style="{StaticResource FieldValue}" Text="{Binding Position}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Created At"/>
                                    <TextBlock Style="{StaticResource FieldValue}"
                                               Text="{Binding CreatedAt, StringFormat='{}{0:MMM d, yyyy}'}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Last Status Updated"/>
                                    <TextBlock Style="{StaticResource FieldValue}"
                                               Text="{Binding LastStatusUpdatedAt, StringFormat='{}{0:MMM d, yyyy}'}"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Job Description"/>
                                <TextBlock Style="{StaticResource FieldValue}" Text="{Binding JobDescription, FallbackValue='—'}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Note"/>
                                <TextBlock Style="{StaticResource FieldValue}" Text="{Binding Note, FallbackValue='—'}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- EDIT MODE -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Company"/>
                                    <TextBox Style="{StaticResource EditInput}"
                                             Text="{Binding EditCompany, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Position"/>
                                    <TextBox Style="{StaticResource EditInput}"
                                             Text="{Binding EditPosition, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Style="{StaticResource FieldLabel}" Text="Job Description"/>
                            <TextBox AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                                     Padding="8,6" BorderBrush="#D1D5DB" FontSize="13" Margin="0,0,0,10"
                                     Text="{Binding EditJobDescription, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Style="{StaticResource FieldLabel}" Text="Note"/>
                            <TextBox AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                                     Padding="8,6" BorderBrush="#D1D5DB" FontSize="13"
                                     Text="{Binding EditNote, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  Current Status -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionTitle}" Text="Current Status" Margin="0"/>
                            <Button Grid.Column="1" Content="View full history"
                                    Height="28" Padding="12,0" FontSize="12"
                                    Command="{Binding OpenHistoryCommand}"/>
                        </Grid>

                        <!-- Last status display -->
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#111827"
                                               Text="{Binding LastStatus.JaStatusType.Label, FallbackValue='—'}"/>
                                    <TextBlock FontSize="12" Foreground="Gray" Margin="0,2,0,0"
                                               Text="{Binding LastStatus.CreatedAt, StringFormat='{}{0:MMM d, yyyy}', FallbackValue=''}"/>
                                    <TextBlock FontSize="13" Foreground="#374151" Margin="0,6,0,0"
                                               TextWrapping="Wrap"
                                               Text="{Binding LastStatus.Note, FallbackValue=''}"
                                               Visibility="{Binding LastStatus.Note, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                    <Button Content="Edit" Height="28" Padding="10,0" Margin="0,0,6,0" FontSize="12"
                                            Command="{Binding OpenEditStatusCommand}"/>
                                    <Button Content="Delete" Height="28" Padding="10,0" FontSize="12"
                                            Command="{Binding DeleteLastStatusCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Button Content="+ Add Status" HorizontalAlignment="Left"
                                Height="32" Padding="14,0" FontSize="13"
                                Command="{Binding OpenAddStatusCommand}"/>
                    </StackPanel>
                </Border>

                <!-- Upcoming Event  -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionTitle}" Text="Upcoming Event" Margin="0"/>
                            <Button Grid.Column="1" Content="+ Add Event"
                                    Height="28" Padding="12,0" FontSize="12"
                                    Command="{Binding OpenAddEventCommand}"/>
                        </Grid>

                        <!-- Has event -->
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="14">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UpcomingEvent}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#111827"
                                               Text="{Binding UpcomingEvent.EventName}"/>
                                    <TextBlock FontSize="12" Foreground="Gray" Margin="0,2,0,0"
                                               Text="{Binding UpcomingEvent.EventType.Label}"/>
                                    <TextBlock FontSize="12" Foreground="Gray" Margin="0,2,0,0"
                                               Text="{Binding UpcomingEvent.EventDate, StringFormat='{}{0:MMM d, yyyy HH:mm}'}"/>
                                    <TextBlock FontSize="13" Foreground="#374151" Margin="0,6,0,0"
                                               TextWrapping="Wrap"
                                               Text="{Binding UpcomingEvent.Note, FallbackValue=''}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                    <Button Content="Edit" Height="28" Padding="10,0" Margin="0,0,6,0" FontSize="12"
                                            Command="{Binding OpenEditEventCommand}"/>
                                    <Button Content="Delete" Height="28" Padding="10,0" FontSize="12"
                                            Command="{Binding DeleteEventCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- No event -->
                        <TextBlock Text="No upcoming event." FontSize="13" Foreground="Gray">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UpcomingEvent}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Status History Overlay -->
        <Grid Visibility="{Binding IsHistoryOpen, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource Overlay}"/>
            <Border Style="{StaticResource Dialog}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Status History" FontSize="18" FontWeight="Bold"/>
                        <Button Grid.Column="1" Content="✕" Width="28" Height="28"
                                Command="{Binding CloseHistoryCommand}"/>
                    </Grid>

                    <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding StatusHistory}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" FontSize="13" Foreground="#111827"
                                                           Text="{Binding JaStatusType.Label}"/>
                                                <TextBlock FontSize="12" Foreground="Gray"
                                                           Text="{Binding CreatedAt, StringFormat='{}{0:MMM d, yyyy}'}"/>
                                                <TextBlock FontSize="13" Foreground="#374151" Margin="0,4,0,0"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Note, FallbackValue=''}"/>
                                                <!-- Events under this status -->
                                                <ItemsControl ItemsSource="{Binding Events}" Margin="0,6,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#F9FAFB" CornerRadius="6"
                                                                    Padding="10,6" Margin="0,0,0,4">
                                                                <StackPanel>
                                                                    <TextBlock FontSize="12" FontWeight="SemiBold"
                                                                               Text="{Binding EventName}"/>
                                                                    <TextBlock FontSize="11" Foreground="Gray"
                                                                               Text="{Binding EventType.Label}"/>
                                                                    <TextBlock FontSize="11" Foreground="Gray"
                                                                               Text="{Binding EventDate, StringFormat='{}{0:MMM d, yyyy HH:mm}'}"/>
                                                                    <TextBlock FontSize="12" Foreground="#374151"
                                                                               TextWrapping="Wrap"
                                                                               Text="{Binding Note, FallbackValue=''}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Add Status Overlay -->
        <Grid Visibility="{Binding IsAddStatusOpen, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource Overlay}"/>
            <Border Style="{StaticResource Dialog}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Add Status" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Status Type (value)"/>
                    <TextBox Style="{StaticResource EditInput}"
                             Text="{Binding NewStatusType, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Note (optional)"/>
                    <TextBox AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                             Padding="8,6" BorderBrush="#D1D5DB" FontSize="13" Margin="0,0,0,16"
                             Text="{Binding NewStatusNote, UpdateSourceTrigger=PropertyChanged}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Height="34" Padding="16,0" Margin="0,0,8,0"
                                Command="{Binding CloseAddStatusCommand}"/>
                        <Button Content="Add" Height="34" Padding="16,0"
                                Command="{Binding ConfirmAddStatusCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Edit Status Overlay -->
        <Grid Visibility="{Binding IsEditStatusOpen, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource Overlay}"/>
            <Border Style="{StaticResource Dialog}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Edit Status" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Status Type (value)"/>
                    <TextBox Style="{StaticResource EditInput}"
                             Text="{Binding EditStatusType, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Note (optional)"/>
                    <TextBox AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                             Padding="8,6" BorderBrush="#D1D5DB" FontSize="13" Margin="0,0,0,16"
                             Text="{Binding EditStatusNote, UpdateSourceTrigger=PropertyChanged}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Height="34" Padding="16,0" Margin="0,0,8,0"
                                Command="{Binding CloseEditStatusCommand}"/>
                        <Button Content="Save" Height="34" Padding="16,0"
                                Command="{Binding ConfirmEditStatusCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Add Event Overlay -->
        <Grid Visibility="{Binding IsAddEventOpen, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource Overlay}"/>
            <Border Style="{StaticResource Dialog}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Add Event" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Name"/>
                    <TextBox Style="{StaticResource EditInput}"
                             Text="{Binding NewEventName, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Type (value)"/>
                    <TextBox Style="{StaticResource EditInput}"
                             Text="{Binding NewEventType, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Date &amp; Time"/>
                    <TextBox Style="{StaticResource EditInput}"
                             Text="{Binding NewEventDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}', UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Note (optional)"/>
                    <TextBox AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                             Padding="8,6" BorderBrush="#D1D5DB" FontSize="13" Margin="0,0,0,16"
                             Text="{Binding NewEventNote, UpdateSourceTrigger=PropertyChanged}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Height="34" Padding="16,0" Margin="0,0,8,0"
                                Command="{Binding CloseAddEventCommand}"/>
                        <Button Content="Add" Height="34" Padding="16,0"
                                Command="{Binding ConfirmAddEventCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Edit Event Overlay -->
        <Grid Visibility="{Binding IsEditEventOpen, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource Overlay}"/>
            <Border Style="{StaticResource Dialog}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Edit Event" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Name"/>
                    <TextBox Style="{StaticResource EditInput}"
                             Text="{Binding EditEventName, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Type (value)"/>
                    <TextBox Style="{StaticResource EditInput}"
                             Text="{Binding EditEventType, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Date &amp; Time"/>
                    <TextBox Style="{StaticResource EditInput}"
                             Text="{Binding EditEventDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}', UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Note (optional)"/>
                    <TextBox AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                             Padding="8,6" BorderBrush="#D1D5DB" FontSize="13" Margin="0,0,0,16"
                             Text="{Binding EditEventNote, UpdateSourceTrigger=PropertyChanged}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Height="34" Padding="16,0" Margin="0,0,8,0"
                                Command="{Binding CloseEditEventCommand}"/>
                        <Button Content="Save" Height="34" Padding="16,0"
                                Command="{Binding ConfirmEditEventCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Page>