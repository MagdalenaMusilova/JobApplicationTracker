<Page x:Class="JobApplicationTracker.Wpf.Views.ApplicationsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F3F4F6">

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Applications"
                   FontSize="36"
                   FontWeight="Bold"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0 20">

            <TextBox Width="300"
                     Height="40"
                     Text="Search company or position"/>

            <Button Content="Add Application"
                    Width="180"
                    Height="40"
                    Margin="20 0"/>
        </StackPanel>

        <Border Grid.Row="2"
                Background="White"
                Padding="10">

            <DataGrid AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      RowHeight="40">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Company"
                                        Binding="{Binding Company}"/>

                    <DataGridTextColumn Header="Position"
                                        Binding="{Binding Position}"/>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"/>

                    <DataGridTextColumn Header="Applied"
                                        Binding="{Binding Date}"/>

                    <DataGridTextColumn Header="Match Score"
                                        Binding="{Binding Match}"/>
                </DataGrid.Columns>

                <DataGrid.Items>
                    <x:Array Type="{x:Type sys:String}"
                             xmlns:sys="clr-namespace:System;assembly=mscorlib">
                    </x:Array>
                </DataGrid.Items>
            </DataGrid>
        </Border>
    </Grid>
</Page>