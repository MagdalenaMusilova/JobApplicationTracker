<Page x:Class="JobApplicationTracker.Wpf.Views.TodoView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F3F4F6">

    <ScrollViewer>
        <StackPanel Margin="30">

            <TextBlock Text="Todo / Calendar" FontSize="36" FontWeight="Bold"/>
            <TextBlock Text="Upcoming interviews, follow-ups, and reminders."
                       FontSize="14" Foreground="Gray" Margin="0 4 0 24"/>

            <!-- Month navigator -->
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0 0 0 16">
                <StackPanel>
                    <Grid Margin="0 0 0 12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="‹" Width="36" Height="36" Click="PrevMonth_Click"/>
                        <TextBlock x:Name="MonthLabel" Grid.Column="1"
                                   FontSize="18" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Button Content="›" Grid.Column="2" Width="36" Height="36" Click="NextMonth_Click"/>
                    </Grid>

                    <!-- Day-of-week headers -->
                    <UniformGrid Rows="1" Columns="7" Margin="0 0 0 4">
                        <TextBlock Text="Mon" HorizontalAlignment="Center" FontSize="12" Foreground="Gray"/>
                        <TextBlock Text="Tue" HorizontalAlignment="Center" FontSize="12" Foreground="Gray"/>
                        <TextBlock Text="Wed" HorizontalAlignment="Center" FontSize="12" Foreground="Gray"/>
                        <TextBlock Text="Thu" HorizontalAlignment="Center" FontSize="12" Foreground="Gray"/>
                        <TextBlock Text="Fri" HorizontalAlignment="Center" FontSize="12" Foreground="Gray"/>
                        <TextBlock Text="Sat" HorizontalAlignment="Center" FontSize="12" Foreground="Gray"/>
                        <TextBlock Text="Sun" HorizontalAlignment="Center" FontSize="12" Foreground="Gray"/>
                    </UniformGrid>

                    <ContentControl x:Name="CalendarGrid"/>
                </StackPanel>
            </Border>

            <!-- Upcoming events list -->
            <Border Background="White" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="Upcoming events (next 14 days)"
                               FontSize="18" FontWeight="Bold" Margin="0 0 0 12"/>
                    <ItemsControl x:Name="EventsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E5E7EB" BorderThickness="0 0 0 1" Padding="0 10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Company}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding EventDescription}" Foreground="Gray" FontSize="13"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding EventDate}"
                                                   Foreground="#2563EB" VerticalAlignment="Center" FontSize="13"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="NoEventsText" Text="No scheduled events in the next 14 days."
                               Foreground="Gray" Margin="0 8"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>