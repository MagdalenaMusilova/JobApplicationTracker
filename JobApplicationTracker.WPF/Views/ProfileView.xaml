<Page x:Class="JobApplicationTracker.Wpf.Views.ProfileView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F3F4F6">

    <ScrollViewer>
        <StackPanel Margin="30"
                    Width="700">

            <TextBlock Text="Profile"
                       FontSize="36"
                       FontWeight="Bold"/>

            <Border Background="White"
                    Margin="0 20"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Personal Information"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0 0 0 20"/>

                    <TextBlock Text="Full Name"/>
                    <TextBox Height="40"
                             Margin="0 5 0 15"
                             Text="John Doe"/>

                    <TextBlock Text="Email"/>
                    <TextBox Height="40"
                             Margin="0 5 0 15"
                             Text="john@email.com"/>

                    <TextBlock Text="Skills"/>
                    <TextBox Height="100"
                             AcceptsReturn="True"
                             Text="C#, .NET, SQL, Azure"/>

                    <Button Content="Save Profile"
                            Width="180"
                            Height="40"
                            Margin="0 20 0 0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>