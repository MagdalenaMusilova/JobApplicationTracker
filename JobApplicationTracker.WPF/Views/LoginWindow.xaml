<Window x:Class="JobApplicationTracker.Wpf.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Job Tracker — Login"
        Width="440" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F3F4F6">

    <Border Margin="40" Background="White" Padding="32"
            CornerRadius="12">
        <StackPanel VerticalAlignment="Center">

            <TextBlock Text="JobTracker"
                       FontSize="28" FontWeight="Bold"
                       Foreground="#111827" HorizontalAlignment="Center"/>

            <TextBlock x:Name="SubtitleText"
                       Text="Welcome back — log in to continue"
                       FontSize="14" Foreground="Gray"
                       HorizontalAlignment="Center"
                       Margin="0 8 0 28"/>

            <TextBlock Text="Username" Margin="0 0 0 4"/>
            <TextBox x:Name="UsernameBox" Height="40" Padding="10 0"
                     VerticalContentAlignment="Center" Margin="0 0 0 14"/>

            <TextBlock Text="Password" Margin="0 0 0 4"/>
            <PasswordBox x:Name="PasswordBox" Height="40" Padding="10 0"
                         VerticalContentAlignment="Center" Margin="0 0 0 20"/>

            <TextBlock x:Name="ErrorText" Foreground="#DC2626"
                       Visibility="Collapsed" Margin="0 0 0 12"
                       TextWrapping="Wrap"/>

            <Button x:Name="PrimaryButton" Height="42"
                    Background="#2563EB" Foreground="White"
                    FontWeight="SemiBold" BorderThickness="0"
                    Click="PrimaryButton_Click"/>

            <Button x:Name="ToggleModeButton" Height="38" Margin="0 10 0 0"
                    Background="Transparent" Foreground="#2563EB"
                    BorderThickness="0"
                    Click="ToggleModeButton_Click"/>
        </StackPanel>
    </Border>
</Window>